generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== SETTINGS ====================

model Settings {
  id              String   @id @default("default")
  businessName    String   @default("My Business")
  businessDesc    String   @default("")
  welcomeMessage  String   @default("Hello! How can I help you today?")
  tone            String   @default("friendly")
  language        String   @default("auto")
  aiProvider      String   @default("openai")
  aiModel         String   @default("gpt-4o-mini")
  aiApiKey        String   @default("")
  maxTokens       Int      @default(2048)
  temperature     Float    @default(0.7)
  elevenLabsKey   String   @default("")
  elevenLabsVoice String   @default("")
  twilioSid       String   @default("")
  twilioToken     String   @default("")
  twilioPhone     String   @default("")
  smtpHost        String   @default("")
  smtpPort        Int      @default(587)
  smtpUser        String   @default("")
  smtpPass        String   @default("")
  smtpFrom        String   @default("")
  imapHost        String   @default("")
  imapPort        Int      @default(993)
  imapUser        String   @default("")
  imapPass        String   @default("")
  whatsappMode    String   @default("web")
  whatsappApiKey  String   @default("")
  whatsappPhone   String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== AUTH ====================

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String   @default("Admin")
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== KNOWLEDGE BASE ====================

model Category {
  id          String           @id @default(uuid())
  name        String
  description String           @default("")
  icon        String           @default("folder")
  color       String           @default("#4A7C9B")
  sortOrder   Int              @default(0)
  entries     KnowledgeEntry[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model KnowledgeEntry {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title      String
  content    String
  priority   Int      @default(0)
  isActive   Boolean  @default(true)
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([categoryId])
}

// ==================== TEAM ====================

model Department {
  id          String       @id @default(uuid())
  name        String
  description String       @default("")
  email       String       @default("")
  members     TeamMember[]
  tickets     Ticket[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamMember {
  id           String     @id @default(uuid())
  name         String
  email        String
  phone        String     @default("")
  role         String     @default("member")
  expertise    String     @default("")
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  isAvailable  Boolean    @default(true)
  tickets      Ticket[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId])
}

// ==================== CONVERSATIONS ====================

model Conversation {
  id              String            @id @default(uuid())
  channel         String
  customerName    String            @default("Unknown")
  customerContact String            @default("")
  status          String            @default("active")
  satisfaction    Int?
  summary         String            @default("")
  metadata        Json              @default("{}")
  messages        Message[]
  tickets         Ticket[]
  tags            ConversationTag[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([channel])
  @@index([status])
  @@index([customerContact])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  mediaType      String?
  mediaUrl       String?
  toolCalls      Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

// ==================== TICKETS ====================

model Ticket {
  id             String        @id @default(uuid())
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  departmentId   String?
  department     Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedToId   String?
  assignedTo     TeamMember?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  title          String
  description    String
  status         String        @default("open")
  priority       String        @default("medium")
  resolution     String        @default("")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([departmentId])
  @@index([assignedToId])
}

// ==================== TAGS ====================

model Tag {
  id            String            @id @default(uuid())
  name          String            @unique
  color         String            @default("#4A7C9B")
  conversations ConversationTag[]
  createdAt     DateTime          @default(now())
}

model ConversationTag {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tagId          String
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([conversationId, tagId])
}

// ==================== CALL LOGS ====================

model CallLog {
  id        String   @id @default(uuid())
  callSid   String   @unique
  from      String
  to        String
  duration  Int      @default(0)
  status    String   @default("initiated")
  recording String?
  summary   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== CHANNELS ====================

model Channel {
  id        String   @id @default(uuid())
  type      String   @unique
  isActive  Boolean  @default(false)
  config    Json     @default("{}")
  status    String   @default("disconnected")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== SCHEDULES ====================

model Schedule {
  id           String @id @default(uuid())
  teamMemberId String
  dayOfWeek    Int
  startTime    String
  endTime      String

  @@index([teamMemberId])
  @@index([dayOfWeek])
}

// ==================== WEBHOOKS ====================

model Webhook {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  url         String
  method      String   @default("POST")
  headers     Json     @default("{}")
  isActive    Boolean  @default(true)
  triggerOn   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== ACTIVITY LOG ====================

model ActivityLog {
  id          String   @id @default(uuid())
  action      String   // conversation.created, ticket.assigned, settings.updated, etc.
  entity      String   // conversation, ticket, settings, knowledge, team
  entityId    String?
  description String
  userId      String?
  userName    String   @default("System")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([entity])
  @@index([createdAt])
}

// ==================== SLA RULES ====================

model SLARule {
  id                String   @id @default(uuid())
  name              String
  description       String   @default("")
  channel           String   @default("all") // all, whatsapp, email, phone
  priority          String   @default("all") // all, low, medium, high, urgent
  firstResponseMins Int      @default(30)
  resolutionMins    Int      @default(480)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ==================== CANNED RESPONSES ====================

model CannedResponse {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String   @default("General")
  shortcut  String   @default("") // e.g., /greeting, /refund
  isActive  Boolean  @default(true)
  usageCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
